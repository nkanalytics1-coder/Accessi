# URL pubblica dell'app (usata nei link delle email)
APP_URL=https://accessi.vercel.app

# Configurazione SMTP per l'invio email
# Gmail: abilita "Password per le app" nelle impostazioni account Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua@email.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Gestione Utenti" <tua@email.com>
